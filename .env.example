# ============================================================
#  Zarix AgentOS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
# ------------------------------------------------------------

# ── Application ──────────────────────────────────────────────
APP_NAME=Zarix AgentOS
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zarix:zarix@localhost:5432/zarix_agentos
REDIS_URL=redis://localhost:6379/0

# ── Vector Database (for RAG / long-term memory) ─────────────
VECTOR_DB_TYPE=chroma
VECTOR_DB_URL=http://localhost:8001
VECTOR_DB_COLLECTION=zarix_memory

# ── LLM Provider API Keys ────────────────────────────────────
# OpenAI
OPENAI_API_KEY=
# Anthropic
ANTHROPIC_API_KEY=
# Google Gemini
GOOGLE_API_KEY=
# Meta Llama (via Together / Groq / local)
META_API_KEY=
META_BASE_URL=https://api.together.xyz/v1
# Mistral
MISTRAL_API_KEY=
# DeepSeek
DEEPSEEK_API_KEY=

# ── Default LLM Settings ────────────────────────────────────
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120

# ── Tool / Sandbox Settings ─────────────────────────────────
ENABLE_CODE_EXECUTION=true
ENABLE_WEB_SEARCH=true
ENABLE_SHELL_ACCESS=false
SANDBOX_TIMEOUT=60

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
